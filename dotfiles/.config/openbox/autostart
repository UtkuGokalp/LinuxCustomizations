nitrogen --restore &
picom --backend xrender &

xinput set-prop 9 "libinput Accel Profile Enabled" 0, 0, 0
xinput set-prop 10 "libinput Accel Profile Enabled" 0, 0, 0
xinput set-prop 9 "libinput Accel Speed" -0.5
xinput set-prop 10 "libinput Accel Speed" -0.5
xrandr --output HDMI-0 --primary
plank &

